repository-code: "https://github.com/masakiwatanabe-labani/FVB-reference-bias-RNAseq"
license: MIT
date-released: "2026-01-01"
keywords:
  - RNA-seq
  - reference bias
  - FVB mouse
  - personalised reference genome
  - g2gtools
  - WASP
  - featureCounts
  - SNP-mediated bias
references:
